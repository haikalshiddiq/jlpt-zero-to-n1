---
import Base from '../layouts/Base.astro';
import { lessons, vocabulary, kanji, grammar, quiz, roadmap } from '../data/curriculum';
---
<Base title="Grammar"><div class="glass"><h1>Grammar Builder</h1></div><section class="grid">{grammar.map(g=><div class="card"><span class="badge">{g.level}</span><h2>{g.pattern}</h2><h3>{g.meaning}</h3><p>{g.use}</p><p class="muted">Mistake: {g.mistake}</p><ul>{g.examples.map(e=><li>{e}</li>)}</ul></div>)}</section></Base>