---
import Base from '../layouts/Base.astro';
import { grammar } from '../lib/curriculum';
import { toRomaji } from '../utils/romaji';
---
<Base title="Grammar">
  <div class="glass">
    <h1>Grammar Builder</h1>
    <p class="lead">Grammar examples now include romaji pronunciation so beginners can read aloud while learning the pattern.</p>
  </div>
  <section class="grid">
    {grammar.map((grammarItem) => <div class="card">
      <span class="badge">{grammarItem.level}</span>
      <h2>{grammarItem.pattern}</h2>
      <p class="pronunciation compact"><span>Pattern pronunciation</span>{toRomaji(grammarItem.pattern)}</p>
      <h3>{grammarItem.meaning}</h3>
      <p>{grammarItem.use}</p>
      <p class="muted">Mistake: {grammarItem.mistake}</p>
      <ul class="example-list">
        {grammarItem.examples.map((example: string) => <li><span class="jp-example">{example}</span><br/><span class="pronunciation inline">{toRomaji(example)}</span></li>)}
      </ul>
    </div>)}
  </section>
</Base>
