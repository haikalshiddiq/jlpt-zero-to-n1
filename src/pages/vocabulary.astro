---
import Base from '../layouts/Base.astro';
import { vocabulary } from '../lib/curriculum';
import { toRomaji } from '../utils/romaji';
---
<Base title="Vocabulary">
  <div class="glass">
    <h1>Vocabulary Flashcards</h1>
    <p class="lead">Click a card to reveal the answer, then practice with romaji pronunciation for every Japanese item.</p>
  </div>
  <section class="grid">
    {vocabulary.map((vocabItem) => <div class="card flashcard">
      <div class="front">
        <p class="badge">{vocabItem.level}</p>
        <div class="jp">{vocabItem.jp}</div>
        <p class="pronunciation"><span>Romaji pronunciation</span>{vocabItem.reading || toRomaji(vocabItem.jp)}</p>
        <button class="btn" data-flip>Show Meaning</button>
      </div>
      <div class="back">
        <h2>{vocabItem.meaning}</h2>
        <p class="jp-example">{vocabItem.example}</p>
        <p class="pronunciation compact"><span>Example pronunciation</span>{toRomaji(vocabItem.example)}</p>
        <p class="muted">{vocabItem.note}</p>
        {vocabItem.tags.map((tag: string) => <span class="badge">{tag}</span>)}
        <p><button class="btn" data-review="easy" data-item={vocabItem.jp}>Easy</button> <button class="btn secondary" data-review="forgot" data-item={vocabItem.jp}>I Forgot</button></p>
      </div>
    </div>)}
  </section>
</Base>
