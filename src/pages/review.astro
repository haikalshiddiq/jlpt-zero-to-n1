---
import Base from '../layouts/Base.astro';
import { reviewDueCount } from '../lib/curriculum';
---
<Base title="Review">
  <div class="glass">
    <h1>Spaced Repetition Review</h1>
    <p class="lead">Cadence: 1 day, 3 days, 7 days, 14 days, 30 days.</p>
  </div>
  <section class="grid">
    <div class="card">
      <h2>Due Today</h2>
      <p class="stat">{reviewDueCount}</p>
      <p>Starter items from Day 1 are due.</p>
    </div>
    <div class="card">
      <h2>Review Queue</h2>
      <div id="queue">Local review history will appear after using flashcards.</div>
    </div>
  </section>
  <script is:inline>
    const storedQueue = jlptStore.get('reviewQueue', []);
    const q = Array.isArray(storedQueue) ? storedQueue : [];
    const queue = document.querySelector('#queue');
    if (queue && q.length) {
      queue.textContent = '';
      q.forEach((x) => {
        const entry = document.createElement('p');
        entry.textContent = `${x.item}: ${x.result}`;
        queue.appendChild(entry);
      });
    } else if (queue) {
      queue.textContent = 'No saved review results yet.';
    }
  </script>
</Base>
