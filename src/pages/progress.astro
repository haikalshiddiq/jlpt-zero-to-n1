---
import Base from '../layouts/Base.astro';
import { progressAreas } from '../lib/curriculum';
---
<Base title="Progress">
  <div class="glass">
    <h1>Progress Tracker</h1>
  </div>
  <section class="grid">
    {progressAreas.map(([area, readiness]) => (
      <div class="card">
        <h2>{area}</h2>
        <div class="progress"><div class="bar" style={`width:${readiness}%`}></div></div>
        <p class="muted">{readiness}% / current foundation baseline</p>
      </div>
    ))}
  </section>
</Base>
