---
import Base from '../layouts/Base.astro';
import { lessons, vocabulary, kanji, grammar, quiz, roadmap } from '../data/curriculum';
---
<Base title="Progress"><div class="glass"><h1>Progress Tracker</h1></div><section class="grid">{['Hiragana/Katakana','Vocabulary','Kanji','Grammar','Reading','Listening','Writing','Speaking','JLPT N5 Readiness'].map((s,i)=><div class="card"><h2>{s}</h2><div class="progress"><div class="bar" style={`width:${[5,20,4,4,2,2,2,2,1][i]}%`}></div></div><p class="muted">{[5,20,4,4,2,2,2,2,1][i]}% / current foundation baseline</p></div>)}</section></Base>