---
import Base from '../layouts/Base.astro';
import { lessons } from '../data/curriculum';
import dailyAdditions from '../data/daily-additions.json';
import { toRomaji } from '../utils/romaji';
const lesson = lessons[1];
const todaysDrop = dailyAdditions[0];
---
<Base title="Daily Lesson">
  <section class="glass">
    <p class="eyebrow">Day {lesson.day} • {lesson.level}</p>
    <h1>{lesson.title}</h1>
    <p class="lead">{lesson.time} • {lesson.difficulty}</p>
    <div class="mission-row">
      <span class="api-pill">review</span><span class="api-pill">vocabulary</span><span class="api-pill">kanji</span><span class="api-pill">grammar</span><span class="api-pill">practice</span>
    </div>
  </section>

  {todaysDrop && <section class="lesson-section quest-card wayground-note">
    <span class="badge hot">Automated CI/CD drop</span>
    <h2>{todaysDrop.title}</h2>
    <p>{todaysDrop.objective}</p>
    <p><strong>Activity:</strong> {todaysDrop.activity}</p>
    <p class="pronunciation compact"><span>Pronunciation support</span>Romaji has been added to vocabulary, kanji, grammar, reading, and listening practice.</p>
    <button class="btn" data-power>Complete power-up</button>
  </section>}

  {lesson.review.length > 0 && <section class="lesson-section card"><h2>Review From Previous Lessons</h2><ul>{lesson.review.map((r) => <li>{r}</li>)}</ul></section>}
  <section class="lesson-section two">
    <div class="card">
      <h2>New Vocabulary</h2>
      {lesson.vocab.map((v) => <article class="mini-study-card">
        <span class="jp">{v.jp}</span>
        <p class="pronunciation"><span>Romaji pronunciation</span>{v.reading || toRomaji(v.jp)}</p>
        <p><b>{v.meaning}</b></p>
        <p class="jp-example">{v.example}</p>
        <p class="pronunciation compact"><span>Example pronunciation</span>{toRomaji(v.example)}</p>
        <p class="muted">{v.note}</p>
      </article>)}
    </div>
    <div class="card">
      <h2>Kanji Study</h2>
      {lesson.kanji.map((k) => <article class="mini-study-card">
        <span class="jp">{k.char}</span> <b>{k.meaning}</b>
        <p>On: {k.onyomi} <span class="pronunciation inline">{toRomaji(k.onyomi)}</span></p>
        <p>Kun: {k.kunyomi} <span class="pronunciation inline">{toRomaji(k.kunyomi)}</span></p>
        <div class="word-list">{k.words.map((word) => <span class="word-chip"><b>{word}</b><small>{toRomaji(word)}</small></span>)}</div>
        <p class="jp-example">{k.example}</p>
        <p class="pronunciation compact"><span>Example pronunciation</span>{toRomaji(k.example)}</p>
      </article>)}
    </div>
  </section>
  <section class="lesson-section card">
    <h2>Grammar Lesson</h2>
    {lesson.grammar.map((g) => <div class="mini-study-card">
      <h3>{g.pattern}</h3>
      <p class="pronunciation compact"><span>Pattern pronunciation</span>{toRomaji(g.pattern)}</p>
      <p><b>{g.meaning}</b> {g.use}</p>
      <p class="muted">Common mistake: {g.mistake}</p>
      <ul>{g.examples.map((e) => <li><span class="jp-example">{e}</span><br/><span class="pronunciation inline">{toRomaji(e)}</span></li>)}</ul>
    </div>)}
  </section>
  <section class="lesson-section two">
    <div class="card">
      <h2>Reading Practice</h2>
      <pre>{lesson.reading}</pre>
      <pre class="romaji-block">{toRomaji(lesson.reading)}</pre>
      {lesson.questions.map((q) => <p>• {q}</p>)}
    </div>
    <div class="card">
      <h2>Listening Simulation</h2>
      <h3>Slow</h3>
      <pre>{lesson.listening.slow}</pre>
      <pre class="romaji-block">{toRomaji(lesson.listening.slow)}</pre>
      <h3>Natural</h3>
      <p>{lesson.listening.natural}</p>
      <p class="pronunciation compact"><span>Natural pronunciation</span>{toRomaji(lesson.listening.natural)}</p>
    </div>
  </section>
  <section class="lesson-section card"><h2>Homework</h2><ul>{lesson.homework.map((h) => <li>{h}</li>)}</ul><a class="btn" href="/jlpt-practice">Take JLPT Practice</a></section>
</Base>
