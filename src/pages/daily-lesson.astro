---
import Base from '../layouts/Base.astro';
import { lessons } from '../data/curriculum';
import dailyAdditions from '../data/daily-additions.json';
const lesson = lessons[1];
const todaysDrop = dailyAdditions[0];
---
<Base title="Daily Lesson">
  <section class="glass">
    <p class="eyebrow">Day {lesson.day} • {lesson.level}</p>
    <h1>{lesson.title}</h1>
    <p class="lead">{lesson.time} • {lesson.difficulty}</p>
    <div class="mission-row">
      <span class="api-pill">review</span><span class="api-pill">vocabulary</span><span class="api-pill">kanji</span><span class="api-pill">grammar</span><span class="api-pill">practice</span>
    </div>
  </section>

  {todaysDrop && <section class="lesson-section quest-card wayground-note">
    <span class="badge hot">Automated CI/CD drop</span>
    <h2>{todaysDrop.title}</h2>
    <p>{todaysDrop.objective}</p>
    <p><strong>Activity:</strong> {todaysDrop.activity}</p>
    <button class="btn" data-power>Complete power-up</button>
  </section>}

  {lesson.review.length>0 && <section class="lesson-section card"><h2>Review From Previous Lessons</h2><ul>{lesson.review.map(r=><li>{r}</li>)}</ul></section>}
  <section class="lesson-section two"><div class="card"><h2>New Vocabulary</h2>{lesson.vocab.map(v=><p><span class="jp">{v.jp}</span><br/><b>{v.reading}</b> — {v.meaning}<br/><span class="muted">{v.example} • {v.note}</span></p>)}</div><div class="card"><h2>Kanji Study</h2>{lesson.kanji.map(k=><p><span class="jp">{k.char}</span> <b>{k.meaning}</b><br/>On: {k.onyomi} • Kun: {k.kunyomi}<br/><span class="muted">{k.words.join(' / ')} — {k.example}</span></p>)}</div></section>
  <section class="lesson-section card"><h2>Grammar Lesson</h2>{lesson.grammar.map(g=><div><h3>{g.pattern}</h3><p><b>{g.meaning}</b> {g.use}</p><p class="muted">Common mistake: {g.mistake}</p><ul>{g.examples.map(e=><li>{e}</li>)}</ul></div>)}</section>
  <section class="lesson-section two"><div class="card"><h2>Reading Practice</h2><pre>{lesson.reading}</pre>{lesson.questions.map(q=><p>• {q}</p>)}</div><div class="card"><h2>Listening Simulation</h2><h3>Slow</h3><pre>{lesson.listening.slow}</pre><h3>Natural</h3><p>{lesson.listening.natural}</p></div></section>
  <section class="lesson-section card"><h2>Homework</h2><ul>{lesson.homework.map(h=><li>{h}</li>)}</ul><a class="btn" href="/jlpt-practice">Take JLPT Practice</a></section>
</Base>
