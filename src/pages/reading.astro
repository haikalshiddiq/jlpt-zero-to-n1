---
import Base from '../layouts/Base.astro';
import { lessons } from '../lib/curriculum';
import { toRomaji } from '../utils/romaji';
---
<Base title="Reading">
  <div class="glass">
    <h1>Reading Practice</h1>
  </div>
  <section class="grid">
    {lessons.map((lesson) => (
      <div class="card">
        <span class="badge">{lesson.level}</span>
        <h2>{lesson.title}</h2>
        <pre>{lesson.reading}</pre>
        <pre class="romaji-block">{toRomaji(lesson.reading)}</pre>
        <button class="btn" data-toggle={`#q-${lesson.id}`}>Show Questions</button>
        <div id={`q-${lesson.id}`} class="hidden">
          {lesson.questions.map((question: string) => <p>• {question}</p>)}
        </div>
      </div>
    ))}
  </section>
</Base>
