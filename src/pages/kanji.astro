---
import Base from '../layouts/Base.astro';
import { kanji } from '../lib/curriculum';
import { toRomaji } from '../utils/romaji';
---
<Base title="Kanji">
  <div class="glass">
    <h1>Kanji Mastery</h1>
    <p class="lead">Each kanji now includes romaji support for readings, sample words, and example sentences.</p>
  </div>
  <section class="grid">
    {kanji.map((kanjiItem) => <div class="card">
      <div class="jp">{kanjiItem.char}</div>
      <h2>{kanjiItem.meaning}</h2>
      <p><b>Onyomi:</b> {kanjiItem.onyomi}<br/><span class="pronunciation inline">{toRomaji(kanjiItem.onyomi)}</span></p>
      <p><b>Kunyomi:</b> {kanjiItem.kunyomi}<br/><span class="pronunciation inline">{toRomaji(kanjiItem.kunyomi)}</span></p>
      <div class="word-list">
        {kanjiItem.words.map((word: string) => <span class="word-chip"><b>{word}</b><small>{toRomaji(word)}</small></span>)}
      </div>
      <p class="jp-example">{kanjiItem.example}</p>
      <p class="pronunciation compact"><span>Example pronunciation</span>{toRomaji(kanjiItem.example)}</p>
      <button class="btn" data-review="good" data-item={kanjiItem.char}>Mark Reviewed</button>
    </div>)}
  </section>
</Base>
