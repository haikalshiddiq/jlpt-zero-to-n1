---
import Base from '../layouts/Base.astro';
import { roadmap } from '../lib/curriculum';
---
<Base title="JLPT Roadmap">
  <div class="glass">
    <p class="eyebrow">Roadmap</p>
    <h1>Pre-N5 → N1 Mastery Path</h1>
  </div>
  <section class="card road">
    {roadmap.map((stage) => (
      <div class="road-item">
        <h2>{stage.level}</h2>
        <p><b>Vocabulary:</b> {stage.vocab} • <b>Kanji:</b> {stage.kanji}</p>
        <p>{stage.goal}</p>
        <div class="progress"><div class="bar" style={`width:${stage.ready}%`}></div></div>
        <p class="muted">Readiness: {stage.ready}%</p>
      </div>
    ))}
  </section>
</Base>
